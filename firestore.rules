rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /resources/{resourceId} {
      // Semua user dapat membaca resource.
      allow read: if true;

      // Semua user dapat menambahkan resource melalui admin panel.
      allow create: if true;

      // Disable update / delete dari client tanpa otentikasi.
      allow update, delete: if false;
    }

    match /practicum_studio_modules/{moduleId} {
      allow read, create, update, delete: if true;
    }

    match /videos/{videoId} {
      allow read, create, update, delete: if true;
    }

    match /announcements/{announcementId} {
      allow read, create, update, delete: if true;
    }

    match /resource_access_logs/{logId} {
      allow read, create: if true;
      allow update: if false;
      allow delete: if true;
    }

    match /admin_audit_logs/{logId} {
      allow read, create: if true;
      allow update: if false;
      allow delete: if true;
    }

    match /admin_push_tokens/{tokenId} {
      allow read, create, update, delete: if true;
    }

    match /admin_activity/{adminId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    match /contact_messages/{messageId} {
      allow read, create, update, delete: if true;
    }

    match /live_chat_messages/{messageId} {
      allow read, create, update, delete: if true;
    }
  }
}
